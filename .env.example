# Environment: development | production
# - development: optional DATABASE_URL, default JWT_SECRET allowed, verbose warnings
# - production: DATABASE_URL and strong JWT_SECRET required (app exits if missing)
ENV=development

# Server
PORT=8080

# Database (required in production; optional in dev for health-only runs)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/fansedu?sslmode=disable

# JWT signing secret. In production use a strong random value, e.g.:
#   openssl rand -base64 32
JWT_SECRET=change-me

# Email (Brevo SMTP) — set BREVO_SMTP_KEY di .env / secret manager; jangan commit.
# BREVO_SMTP_KEY=
# SMTP_FROM=admin@fansedu.web.id
# SMTP_USER=
