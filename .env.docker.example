# Salin ke `.env` di folder yang sama dengan docker-compose.yml.
# File ini dipakai bersama oleh service `redis` dan `api` (env_file).

ENV=production
API_PORT=8080

DATABASE_URL=postgres://USER:PASS@HOST:5432/DBNAME?sslmode=require
JWT_SECRET=ganti-dengan-openssl-rand-base64-32

# URL publik frontend — di server wajib HTTPS, bukan localhost
APP_URL=https://app.domain.com
CORS_ORIGINS=https://app.domain.com

# --- Redis (satu .env untuk redis + api) ---
# Tanpa password (lokal/dev):
REDIS_URL=redis://redis:6379/0
# REDIS_PASSWORD=

# Dengan password (disarankan production): set password DAN sesuaikan REDIS_URL:
# REDIS_PASSWORD=secret-kuat
# REDIS_URL=redis://:secret-kuat@redis:6379/0
# (jika password ada karakter khusus, URL-encode di bagian password)

# Opsional
# GEO_CACHE_TTL_SECONDS=2592000
# LEADERBOARD_CACHE_TTL_SECONDS=3600
