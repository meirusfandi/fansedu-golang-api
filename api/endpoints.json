{
  "basePath": "/api/v1",
  "auth": {
    "type": "jwt",
    "header": "Authorization",
    "format": "Bearer <token>",
    "roles": ["student", "admin"]
  },
  "endpoints": [
    {
      "name": "Health Check",
      "method": "GET",
      "path": "/health",
      "summary": "Service liveness check",
      "auth": "none",
      "requestExample": null,
      "responseExample": {
        "200": {
          "body": {
            "status": "ok",
            "time": "2025-01-01T00:00:00Z"
          }
        }
      }
    },

    {
      "name": "Register",
      "method": "POST",
      "path": "/auth/register",
      "summary": "Register new student account",
      "auth": "none",
      "requestExample": {
        "body": {
          "name": "Jane Doe",
          "email": "jane@example.com",
          "password": "StrongP@ssw0rd"
        }
      },
      "responseExample": {
        "200": {
          "body": {
            "user": {
              "id": "uuid",
              "name": "Jane Doe",
              "email": "jane@example.com",
              "role": "student",
              "avatarUrl": null
            },
            "token": "jwt-token-here"
          }
        }
      }
    },
    {
      "name": "Login",
      "method": "POST",
      "path": "/auth/login",
      "summary": "Login with email & password",
      "auth": "none",
      "requestExample": {
        "body": {
          "email": "jane@example.com",
          "password": "StrongP@ssw0rd"
        }
      },
      "responseExample": {
        "200": {
          "body": {
            "user": {
              "id": "uuid",
              "name": "Jane Doe",
              "email": "jane@example.com",
              "role": "student"
            },
            "token": "jwt-token-here"
          }
        },
        "401": {
          "body": {
            "error": "invalid email or password"
          }
        }
      }
    },
    {
      "name": "Logout",
      "method": "POST",
      "path": "/auth/logout",
      "summary": "Logout current session (JWT client-side)",
      "auth": "user",
      "requestExample": {
        "headers": {
          "Authorization": "Bearer <jwt>"
        }
      },
      "responseExample": {
        "200": {
          "body": {
            "ok": true
          }
        }
      }
    },
    {
      "name": "Forgot Password",
      "method": "POST",
      "path": "/auth/forgot-password",
      "summary": "Request password reset email (stub)",
      "auth": "none",
      "requestExample": {
        "body": {
          "email": "jane@example.com"
        }
      },
      "responseExample": {
        "200": {
          "body": {
            "ok": true
          }
        }
      }
    },
    {
      "name": "Reset Password",
      "method": "POST",
      "path": "/auth/reset-password",
      "summary": "Reset password with token (stub)",
      "auth": "none",
      "requestExample": {
        "body": {
          "token": "reset-token",
          "newPassword": "NewStrongP@ssw0rd"
        }
      },
      "responseExample": {
        "200": {
          "body": {
            "ok": true
          }
        }
      }
    },

