# Development — copy to .env for local runs
# ENV is optional; defaults to development if unset
ENV=development
PORT=8080
# Leave empty to run without DB (/health + /geo/* still work); set for full API
DATABASE_URL=postgres://postgres:postgres@localhost:5432/fansedu?sslmode=disable

# Redis (opsional): geo + leaderboard cache
# Opsi A — satu URL (disarankan, cocok Docker):
# REDIS_URL=redis://localhost:6379/0
# REDIS_URL=redis://:password@localhost:6379/0
# Opsi B — alamat + password terpisah (tanpa REDIS_URL):
# REDIS_ADDR=localhost:6379
# REDIS_PASSWORD=ganti-password-kuat
# REDIS_DB=0
# GEO_UPSTREAM_BASE_URL=https://www.emsifa.com/api-wilayah-indonesia/api
# GEO_CACHE_TTL_SECONDS=2592000
# Cache leaderboard per tryout (Redis); invalidasi saat submit/register (default 3600 detik)
# LEADERBOARD_CACHE_TTL_SECONDS=3600
# Default secret allowed in dev (logs a warning)
JWT_SECRET=change-me
# CORS: * = allow all origins; or comma-separated list e.g. http://localhost:3000,https://app.example.com
# CORS_ORIGINS=*

# Allow login without email verification (dev only; set to 1 or true)
# SKIP_EMAIL_VERIFICATION=1

# URL frontend untuk link di email (konfirmasi pesanan, buat akun). Default: http://localhost:5173
# APP_URL=http://localhost:5173

# Opsional: untuk generate feedback dengan AI saat siswa submit tryout (OpenAI). Kosongkan = pakai feedback rule-based.
# OPENAI_API_KEY=sk-...

# Email transaksi (Brevo SMTP). Tanpa ini, email hanya dicetak ke log (LogMailer).
# Kunci SMTP dari dashboard Brevo (bukan dipublikasikan di repo).
# BREVO_SMTP_KEY=xkeysib-...
# SMTP_USER=email-login-brevo@domain.com   # opsional; default = SMTP_FROM
# SMTP_FROM=admin@fansedu.web.id
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
